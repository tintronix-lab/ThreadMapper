    },
    "Trajectories are computed by comparing each device's recent signal readings against a rolling 24-hour baseline. A device is marked declining if its recent average is meaningfully below baseline, and critical if it falls below the worst observed baseline reading." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trajektorier beräknas genom att jämföra varje enhets senaste signalmätningar mot ett rullande 24-timmarsbaskarta. En enhet markeras som sjunkande om dess senaste genomsnitt är väsentligt under baskartan, och kritisk om det faller under den sämsta observerade baskartemätningen."
          }
        }
      }
    },
    "Trend" : {
      "extractionState" : "stale",
