        }
      }
    },
    "%@ should be back online shortly. If it doesn't reappear in the next minute, try restarting the app.": {
      "comment": "A message that informs the user that a device is back online. The argument is the name of the device.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ borde vara online inom kort. Om den inte dyker upp inom en minut, prova att starta om appen."
          }
        }
      }
    },
    "%@ showing critical signal drop": {
