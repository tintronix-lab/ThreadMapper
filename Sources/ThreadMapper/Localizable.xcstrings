    "ThreadMapper Pro" : {
      "comment" : "The title of the screen.",
      "isCommentAutoGenerated" : true
    },
    "ThreadMapper Pro unlocks:" : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ThreadMapper Pro låser upp:"
          }
        }
      }
    },
    "ThreadMapper provides a medium Home Screen widget. Long-press your Home Screen → tap the + button → search for \"ThreadMapper\" → choose the medium size → tap Add Widget." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ThreadMapper tillhandahåller en medium hemskärmswidget. Håll ned hemskärmen → tryck på +-knappen → sök efter \"ThreadMapper\" → välj mellanstorlek → tryck på Lägg till widget."
          }
        }
      }
    },
    "ThreadMapper reads HomeKit exclusively. If HomeKit doesn't know about a device, ThreadMapper cannot see it either." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ThreadMapper läser HomeKit exklusivt. Om HomeKit inte känner till en enhet kan ThreadMapper inte se den heller."
          }
        }
      }
    },
    "ThreadMapper reads your HomeKit Thread network and visualises every device, link, and health metric so you can see exactly how your mesh is performing." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ThreadMapper läser ditt HomeKit Thread-nätverk och visualiserar varje enhet, länk och hälsomått så att du kan se exakt hur ditt nät presterar."
          }
        }
      }
    },
    "ThreadMapper records a change entry whenever the firmware version reported by HomeKit differs from the previously known version." : {
      "comment" : "A description of the firmware version change log.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
