        }
      }
    },
    "%@ dB margin" : {
      "comment" : "A label showing the margin between the current device's RSSI and the neighbor's.",
      "isCommentAutoGenerated" : true
    },
    "%@ dBm" : {
      "comment" : "A label displaying the RSSI value of a device. The argument is the RSSI value, e.g. \"-40 dBm\"",
      "isCommentAutoGenerated" : true
    },
    "%@ has a router (%@) but still grades %@. Metal appliances, thick walls, or distance may be absorbing signal. Try moving the router to a more central location or elevated shelf." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ har en router (%@) men betygsätts fortfarande %@. Metallföremål, tjocka väggar eller avstånd kan absorbera signalen. Prova att flytta routern till en mer central plats."
          }
        }
      }
    },
    "%@ has a weak signal and may miss triggers. %@ in the same area has a stronger, more reliable connection — use it as the trigger device for time-sensitive automations instead." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ har en svag signal och kan missa utlösningar. %@ i samma område har en starkare, mer tillförlitlig anslutning – använd den som utlösningsenhet för tidskritiska automationer istället."
          }
        }
      }
    },
    "%@ has gone offline %lld times recently. Create a HomeKit automation to notify you immediately when it loses connection so you can act before it affects other automations." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ har gått offline %lld gånger nyligen. Skapa en HomeKit-automation för att få en omedelbar avisering när enheten tappar anslutningen, så att du kan agera innan det påverkar andra automationer."
          }
        }
      }
    },
    "%@ has grade %@ coverage with %lld devices and no Thread router. A mains-powered Eve, Nanoleaf, or IKEA Thread device in this room would act as a relay, extending coverage to nearby devices." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ har täckningsbetyget %@ med %lld enheter och ingen Thread-router. En elnätsansluten Eve-, Nanoleaf- eller IKEA Thread-enhet i det här rummet fungerar som relä och utökar täckningen."
          }
        }
      }
    },
    "%@ has joined your mesh for the first time." : {
      "comment" : "The name of the device that has just joined the network.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ har gått med i ditt nät för första gången."
