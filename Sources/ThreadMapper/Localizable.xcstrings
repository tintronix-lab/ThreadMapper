    "%@ appears isolated — no inferred path to a border router. Move it closer to the mesh or add a router between it and the nearest Thread device." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ verkar isolerad – ingen väg till en gränssnittsrouter kunde fastställas. Flytta den närmare nätverket eller lägg till en router mellan den och närmaste Thread-enhet."
          }
        }
      }
    },
    "%@ caused the most disruption with %lld offline %@." : {
      "comment" : "A sentence describing an offline event. The argument is the name of the device, the second argument is the number of events.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ caused the most disruption with %2$lld offline %3$@."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ orsakade störst avbrott med %2$lld offline %3$@."
          }
        }
      }
    },
    "%@ caused the most disruption with %lld offline events." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ orsakade mest störningar med %lld nätverksavbrott."
