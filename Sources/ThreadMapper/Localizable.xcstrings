          }
        }
      }
    },
    "ThreadMapper registers Siri App Shortcuts available immediately after install: \"Check my Thread network\" (reads out your grade and device count) and \"Show offline devices\" (opens the app focused on offline devices)." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
