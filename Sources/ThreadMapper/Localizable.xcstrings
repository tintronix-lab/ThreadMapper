    "%@ (%@) is unreachable": {
      "comment": "The body of a notification that alerts the user that a Thread device is offline. The first argument is the name of the device. The second argument is the room name, if available.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ (%2$@) is unreachable"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ (%2$@) är inte nåbar"
          }
        }
      }
    },
    "%@ (est.)": {
      "comment": "A label that shows the RSSI value and a corresponding icon.",
      "isCommentAutoGenerated": true
    },
    "%@ → %@": {
      "comment": "A firmware version change.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ → %2$@"
          }
