{
  "sourceLanguage": "en",
  "strings": {
    "": {},
    "  %@ → ^[%lld device](inflect: true) isolated if removed": {
      "comment": "A line in a failure impact analysis report. The first argument is the name of the node. The second argument is the number of isolated devices. The third argument is a comma-separated list of the isolated device names.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "  %1$@ → ^[%2$lld device](inflect: true) isolated if removed"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "  %1$@ → ^[%2$lld enhet](inflect: true) isolerade om borttagen"
          }
        }
      }
    },
    "  %@: ^[%lld device](inflect: true)": {
      "comment": "A sentence that describes the number of devices at a specific mesh hop count. The argument is the number of devices, the second argument is the number of hops.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "  %1$@: ^[%2$lld device](inflect: true)"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "  %1$@: ^[%2$lld enhet](inflect: true)"
          }
        }
      }
    },
    "  CH %lld (%lld MHz) — %@ interference risk, ^[%lld device](inflect: true)": {
      "comment": "Channel analysis line. The first argument is the channel number. The second argument is the frequency in MHz.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "  CH %1$lld (%2$lld MHz) — %3$@ interference risk, ^[%4$lld device](inflect: true)"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "  KN %1$lld (%2$lld MHz) — %3$@ störningsrisk, ^[%4$lld enhet](inflect: true)"
          }
        }
      }
    },
    "  Cluster %lld: ^[%lld device](inflect: true) — missing link: %@": {
      "comment": "A description of a single isolated cluster. The argument is the cluster index (starting at 1).",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "  Cluster %1$lld: ^[%2$lld device](inflect: true) — missing link: %3$@"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "  Kluster %1$lld: ^[%2$lld enhet](inflect: true) — saknar länk: %3$@"
          }
        }
      }
    },
    " interference risk": {
      "comment": "A description of the interference risk of a network channel.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "störningsrisk"
          }
        }
      }
    },
    " Wi-Fi interference risk": {
      "comment": "A description of the Wi-Fi interference risk.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi-störningsrisk"
          }
        }
      }
    },
    "·": {
      "comment": "A separator between the channel and hop count",
      "isCommentAutoGenerated": true
    },
    "· %@": {
      "comment": "A comma-separated list of a device's name, type, and room.",
      "isCommentAutoGenerated": true
    },
    "· %lld offline": {
      "comment": "A label that indicates that a device is offline.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "· %lld offline"
          }
        }
      }
    },
    "· %lld samples": {
      "comment": "A label that shows the number of samples and weak devices in a survey. The first argument is the number of samples in the survey. The second argument is the number of weak devices in the survey.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "· %lld mätningar"
          }
        }
      }
    },
    "· %lld weak": {
      "comment": "A label indicating that a certain number of devices are \"weak\" in a room.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "· %lld svaga"
          }
        }
      }
    },
    "· CH %lld": {
      "comment": "A label showing the channel number of a thread network.",
      "isCommentAutoGenerated": true
    },
    "· PAN %@": {
      "comment": "A label that shows the PAN ID of a Thread network.",
      "isCommentAutoGenerated": true
    },
    "/100": {
      "comment": "A slash followed by the number 100.",
      "isCommentAutoGenerated": true
    },
