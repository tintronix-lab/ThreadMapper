      }
    },
    "Tap Share Diagnostic Report at the bottom of the Network Diagnostics sheet to export a plain-text summary including all recommendations, room grades, hop-count table, and channel assignments." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
