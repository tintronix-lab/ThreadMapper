        }
      }
    },
    "For Sleepy End Devices (battery-powered devices that poll infrequently), the Battery section includes a days-remaining estimate alongside the raw percentage." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
