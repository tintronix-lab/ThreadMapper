          }
        }
      }
    },
    "ThreadMapper records device events as your network changes. Check back after devices have joined, left, or gone offline." : {
      "comment" : "A description of the empty state of the device history view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ThreadMapper registrerar enhetshändelser när ditt nätverk förändras. Kom tillbaka efter att enheter har anslutit, lämnat eller gått offline."
          }
        }
      }
    },
    "ThreadMapper records device events here as your network changes — offline alerts, topology shifts, and health score changes." : {
      "comment" : "A description of the purpose of the activity feed.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
