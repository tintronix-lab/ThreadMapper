            "state" : "translated",
            "value" : "Idag"
          }
        }
      }
    },
    "Toggle \"New Device Alerts\" in Settings → Notifications to enable or disable push notifications when an unknown device joins your Thread network." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Växla \"Nya enhetsaviseringar\" i Inställningar → Aviseringar för att aktivera eller inaktivera push-aviseringar när en okänd enhet ansluter ditt Thread-nätverk."
          }
        }
      }
    },
    "Toggle \"Proactive AI Insights\" in Settings → Notifications to enable AI-generated push notifications when critical anomalies are detected. Requires iOS 26 and Apple Intelligence." : {
