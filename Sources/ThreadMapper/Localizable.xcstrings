          }
        }
      }
    },
    "On iOS 26 with Apple Intelligence enabled, an \"AI Device Summary\" section appears near the top of each Device Detail sheet. It contains a 2-sentence plain-English assessment generated on-device, covering current signal health relative to the device's own baseline, any anomaly trajectory, and battery context where relevant." : {
      "extractionState" : "stale",
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
