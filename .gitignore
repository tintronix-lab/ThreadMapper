# --- Xcode / iOS ---
*.xcworkspace
*.xcuserdata
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/project.xcworkspace
!*.xcodeproj/xcshareddata
# Per-developer Xcode UI state. The `!…/project.xcworkspace` rule above re-includes
# everything beneath it, which otherwise tracks this binary and churns it on every
# Xcode session. Directory is `xcuserdata`, so the `*.xcuserdata` glob misses it.
**/xcuserdata/
*.xcuserstate
*.ipa
*.dSYM
*.ipa

# --- SPM / Swift ---
.build/
build/
DerivedData/
*.swiftpm
Package.resolved

# --- macOS / system ---
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems

# --- Build artifacts ---
*.o
*.pyc
__pycache__/
*.so
*.dylib

# --- Credentials / secrets ---
*.p12
*.pem
*.mobileprovision
*.cer
*.p8
AuthKey_*.p8
